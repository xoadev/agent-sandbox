{
  "image": "agent-sandbox-internal:latest",
  "vault": [
    {
      "match": { "host": "api.github.com" },
      "inject": { "headers": { "Authorization": "Bearer {{secrets.github}}" } }
    },
    {
      "match": { "host": "api.anthropic.com" },
      "inject": { "headers": { "x-api-key": "{{secrets.anthropic}}" } }
    }
  ]
}